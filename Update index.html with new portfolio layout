    padding: 50px 20px;
}
#about p { max-width:700px; margin:0 auto; font-size:1.15em; line-height:1.6; }

/* --- Skills Section --- */
#skills-section { text-align:center; opacity:0; transform:translateY(20px); }
#skills-section .skill-icons {
    display:flex;
    justify-content:center;
    flex-wrap:wrap;
    gap:25px;
    margin-top:30px;
}
#skills-section .skill-icons img {
    width:60px; height:60px;
    transition: transform 0.4s;
}
#skills-section .skill-icons img:hover { transform: scale(1.4); }

/* --- Projects --- */
.projects { 
    display:grid; 
    grid-template-columns:repeat(auto-fit,minmax(300px,1fr)); 
    gap:25px; 
    margin:0 auto; 
    max-width:1200px; 
}
.project-card {
    position: relative;
    background:white;
    border-radius:15px;
    overflow:hidden;
    box-shadow:0 8px 20px rgba(0,0,0,0.1);
    transition:0.4s;
    opacity:0;
    transform:translateY(30px);
}
.project-card img { 
    width:100%; 
    height:220px; 
    object-fit:cover; 
    transition: transform 0.4s;
}
.project-card:hover img { transform: scale(1.05); }
.project-card:hover { transform:translateY(-10px); box-shadow:0 12px 25px rgba(0,0,0,0.2); }
.project-card h3 { margin:15px 0 10px; }
.project-card p {
    margin:0 20px 15px 20px;
    font-size:0.95em;
    color:#333;
    transition: 0.3s;
}

/* Project overlay on hover */
