    cursor:pointer; transition:0.4s;
}
#contact button:hover { background:#005a9e; transform:scale(1.05); }

/* --- Footer --- */
footer { background:#222; color:white; text-align:center; padding:30px 20px; }
footer a { color:#00bfff; margin:0 10px; transition: 0.3s; }
footer a:hover { color:#ffeb3b; }

/* --- Responsive --- */
@media(max-width:768px){
    header h1{font-size:2.2em;}
    header p{font-size:1em;}
}

/* Fade-in class */
.visible { opacity:1 !important; transform: translateY(0) !important; transition: all 0.8s ease-in-out; }
</style>
</head>
