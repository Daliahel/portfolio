    overflow: hidden;
    color: white;
    text-align: center;
    padding: 140px 20px 80px;
    background: linear-gradient(rgba(0,0,0,0.3), rgba(0,0,0,0.3)), url('https://images.unsplash.com/photo-1509395176047-4a66953fd231?auto=format&fit=crop&w=1600&q=80') center/cover no-repeat;
}
header h1 { font-size: 3em; margin-bottom: 15px; text-shadow: 2px 2px 8px rgba(0,0,0,0.5); }
header p { font-size: 1.3em; margin-bottom: 25px; text-shadow: 1px 1px 5px rgba(0,0,0,0.5); }

/* --- Hero Buttons --- */
.hero-buttons { margin-top: 20px; }
.hero-buttons .btn {
    background: white;
    color: #0078d4;
    padding: 14px 30px;
    border-radius: 50px;
    margin: 0 10px;
    font-weight: bold;
    transition: all 0.4s ease;
    box-shadow: 0 4px 6px rgba(0,0,0,0.15);
    opacity: 0;
    transform: translateY(20px);
}
.hero-buttons .btn:hover {
    background: #005a9e;
    color: white;
    transform: scale(1.1);
    box-shadow: 0 8px 18px rgba(0,0,0,0.3);
}

/* --- Skills Icons --- */
.skills {
    display: flex;
    justify-content: center;
    margin-top: 30px;
    gap: 15px;
    flex-wrap: wrap;
    opacity: 0;
