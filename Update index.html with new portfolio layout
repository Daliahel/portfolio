<style>
/* --- Global --- */
body {
    font-family: 'Segoe UI', Arial, sans-serif;
    background: #f9f9f9;
    margin: 0;
    padding: 0;
    color: #333;
    scroll-behavior: smooth;
}
a { text-decoration: none; color: inherit; }
h1,h2,h3 { margin: 0; }
h2 { font-size: 2em; margin-bottom: 20px; }
section { padding: 60px 20px; }

/* --- Navbar --- */
nav {
    position: sticky;
    top: 0;
    width: 100%;
    background: rgba(0, 120, 212, 0.95);
    z-index: 100;
    display: flex;
    justify-content: center;
    padding: 10px 0;
    box-shadow: 0 2px 5px rgba(0,0,0,0.1);
    backdrop-filter: blur(5px);
}
nav a {
    color: white;
    margin: 0 15px;
    font-weight: bold;
    transition: 0.3s;
    position: relative;
}
nav a.active::after {
    content: '';
    display: block;
