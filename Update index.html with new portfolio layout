<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dalia Heli | Cloud & DevOps Portfolio</title>
    <style>
        /* Base styles */
        body {
            font-family: 'Segoe UI', Arial, sans-serif;
            background-color: #f5f5f5;
            margin: 0;
            padding: 0;
            color: #333;
            scroll-behavior: smooth;
        }

        a {
            text-decoration: none;
        }

        h2 {
            font-size: 2em;
            margin-bottom: 20px;
        }

        section {
            padding: 60px 20px;
        }

        /* Header / Hero */
        header {
            background-color: #0078d4;
            color: white;
            text-align: center;
            padding: 80px 20px 60px 20px;
        }

        header h1 {
            font-size: 3em;
            margin: 0 0 10px 0;
        }

        header p {
            font-size: 1.2em;
            margin: 0 0 20px 0;
        }

        .hero-buttons {
            margin-top: 20px;
        }

        .hero-buttons .btn {
            background-color: white;
            color: #0078d4;
            padding: 12px 25px;
            border-radius: 5px;
            margin: 0 10px;
            font-weight: bold;
            transition: 0.3s;
            box-shadow: 0 4px 6px rgba(0,0,0,0.1);
        }

        .hero-buttons .btn:hover {
            background-color: #005a9e;
            color: white;
        }

        /* Skills in header */
        .skills {
            display: flex;
            justify-content: center;
            margin-top: 30px;
            gap: 15px;
            flex-wrap: wrap;
        }

        .skills img {
            width: 50px;
            height: 50px;
        }

        /* About Me */
        #about {
            background-color: #e6f0fa;
            text-align: center;
        }

        #about p {
            max-width: 700px;
            margin: 0 auto;
            font-size: 1.1em;
            line-height: 1.6;
        }

        /* Skills section */
        #skills {
            text-align: center;
        }

        #skills .skill-icons {
            display: flex;
            justify-content: center;
            flex-wrap: wrap;
            gap: 20px;
            margin-top: 30px;
        }

        #skills .skill-icons img {
            width: 60px;
            height: 60px;
        }

        /* Projects */
        .projects {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
            gap: 25px;
            margin: 0 auto;
            max-width: 1200px;
        }

        .project-card {
            background-color: white;
            border-radius: 10px;
            box-shadow: 0 4px 8px rgba(0,0,0,0.1);
            overflow: hidden;
            text-align: center;
            padding-bottom: 20px;
            transition: 0.3s;
        }

        .project-card:hover {
            transform: translateY(-5px);
            box-shadow: 0 8px 16px rgba(0,0,0,0.2);
        }

        .project-card img {
            width: 100%;
            height: 200px;
            object-fit: cover;
        }

        .project-card h3 {
            margin: 15px 0 10px 0;
        }

        .project-card p {
            margin: 0 20px 15px 20px;
            font-size: 0.95em;
            color: #333;
        }

        .tech-icons img {
            width: 30px;
            height: 30px;
            margin: 0 6px;
        }

        /* Contact form */
        #contact form {
            max-width: 500px;
            margin: 20px auto 0 auto;
            display: flex;
            flex-direction: column;
            gap: 15px;
        }

        #contact input, #contact textarea {
            padding: 10px;
            border-radius: 5px;
            border: 1px solid #ccc;
            font-size: 1em;
        }

        #contact button {
            padding: 12px;
            background-color: #0078d4;
            color: white;
            border: none;
            border-radius: 5px;
            cursor: pointer;
            font-weight: bold;
            transition: 0.3s;
        }

        #contact button:hover {
            background-color: #005a9e;
        }

        /* Footer */
        footer {
            background-color: #222;
            color: white;
            text-align: center;
            padding: 30px 20px;
        }

        footer a {
            color: #00bfff;
            margin: 0 10px;
        }

        /* Responsive tweaks */
        @media(max-width: 768px) {
            header h1 {
                font-size: 2.2em;
            }

            header p {
                font-size: 1em;
            }
        }
    </style>
</head>
<body>

<!-- Header / Hero -->
<header>
    <h1>Dalia Heli</h1>
    <p>Cloud Architect / DevOps Engineer · Stockholm</p>
    <div class="hero-buttons">
        <a href="#projects" class="btn">See Projects</a>
        <a href="CV_Dalia_Heli.pdf" target="_blank" class="btn">Download CV</a>
    </div>
    <div class="skills">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/aws/aws-original.svg" alt="AWS">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/azure/azure-original.svg" alt="Azure">
        <img src="https://cdn.jsdelivr.net/gh/devicons/devicon/icons/github/github-original.svg" alt="GitHub">
